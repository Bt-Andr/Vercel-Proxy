{
  "name": "vercel-dynamic-proxy",
  "version": "1.0.0",
  "private": true,
  "description": "A single Vercel project that dynamically reverse-proxies requests from many web & mobile apps to their respective backends (e.g. Render services behind a VPN).",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test \"test/*.test.ts\"",
    "start": "node --import tsx src/local-server.ts",
    "demo": "node --import tsx scripts/demo.mjs",
    "dev": "vercel dev",
    "deploy": "vercel deploy --prod"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
