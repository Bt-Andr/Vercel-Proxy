# =============================================================================
#  Vercel Dynamic Proxy — environment configuration
# =============================================================================
# Set these in the Vercel dashboard (Project → Settings → Environment Variables)
# or in a local .env file when running `vercel dev`.
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# 1. ROUTES — the heart of the proxy: map an "app key" to a backend URL.
# -----------------------------------------------------------------------------
# NOTE: once an admin store (Upstash, see §6) is connected, routes are managed
# from the /__admin UI and these env values only SEED an empty store. Without a
# store they remain the live source of truth (memory backend).
#
# Option A (recommended): one JSON object in PROXY_ROUTES.
#   - Value can be a plain URL string, or an object for per-route options.
#   - Per-route options:
#       target      (required) backend base URL
#       stripPrefix (optional, default true) strip the /<key> prefix before forwarding
#       keySecret   (optional) per-route shared secret required in the X-Proxy-Key header
#       hosts       (optional) array of custom hostnames that resolve to this route
#       timeoutMs   (optional) override global timeout for this backend
#       disabled    (optional) keep the route but stop serving it
PROXY_ROUTES={"app_x":"https://back-x.onrender.com","app_y":{"target":"https://back-y.onrender.com","stripPrefix":true}}

# Option B: one variable per route. Key is the part after ROUTE_, lowercased.
#   ROUTE_APP_X=https://back-x.onrender.com  ->  app key "app_x"
# ROUTE_APP_X=https://back-x.onrender.com
# ROUTE_APP_Y=https://back-y.onrender.com

# -----------------------------------------------------------------------------
# 2. HOST MAPPING (optional) — route by the incoming Host header (custom domains).
#    Lets an app call its backend transparently with NO path prefix. Configure it
#    per route via the route's "hosts" array (see PROXY_ROUTES above or the admin
#    UI), e.g. point api-x.yourdomain.com (a domain added to this Vercel project)
#    at app key app_x:  {"app_x":{"target":"...","hosts":["api-x.yourdomain.com"]}}

# -----------------------------------------------------------------------------
# 3. SECURITY (optional but recommended for public deployments)
# -----------------------------------------------------------------------------
# Global shared secret. If set, every request must send it in the X-Proxy-Key
# header (or ?__key= query). Leave empty to disable.
# PROXY_GLOBAL_KEY=

# Admin token. REQUIRED to enable the management API + UI at /__admin.
# When unset, the whole admin surface is disabled (returns 403).
# ADMIN_KEY=change-me-to-a-long-random-secret

# -----------------------------------------------------------------------------
# 4. CORS (for browser/web fronts calling the proxy cross-origin)
# -----------------------------------------------------------------------------
# Comma-separated allowed origins, or "*" to allow any. Default: "*".
# When credentials are used, the matching origin is reflected instead of "*".
# PROXY_ALLOWED_ORIGINS=*
# PROXY_ALLOW_CREDENTIALS=false

# -----------------------------------------------------------------------------
# 5. UPSTREAM behaviour
# -----------------------------------------------------------------------------
# Per-request timeout in ms (allow for Render cold starts). Default: 55000.
# PROXY_TIMEOUT_MS=55000
# Retries on network error / timeout for idempotent methods. Default: 1.
# PROXY_MAX_RETRIES=1
# Name of the header used to explicitly target an app key. Default: x-proxy-target.
# PROXY_TARGET_HEADER=x-proxy-target

# -----------------------------------------------------------------------------
# 6. PERSISTENT STORE (recommended for production) — Upstash Redis
# -----------------------------------------------------------------------------
# Without these, routes live in an EPHEMERAL in-memory store (fine for local dev,
# but edits via /__admin won't persist across Vercel instances/redeploys).
# Provision "Upstash for Redis" from the Vercel Marketplace; it injects these:
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
